# Firebase (required for auth + signaling)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# WebRTC TURN relay (optional, needed when phone and web are on different networks)
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
# Optional comma-separated list of TURN URLs. If omitted, metered.ca defaults are used.
NEXT_PUBLIC_TURN_URLS=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:80?transport=tcp,turn:global.relay.metered.ca:443,turn:global.relay.metered.ca:443?transport=tcp

# Old dashboard legacy forms (optional, only needed if those pages are migrated)
NEXT_PUBLIC_WEB3FORMS_ACCOUNT_DELETION_KEY=
NEXT_PUBLIC_WEB3FORMS_DATA_DELETION_KEY=
